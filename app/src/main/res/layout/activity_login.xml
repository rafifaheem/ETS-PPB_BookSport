<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/green_primary">

    <!-- Top section - Logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="60dp">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_logo"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BOOKSPORT"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.15"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pesan lapangan, main sekarang"
            android:textSize="14sp"
            android:textColor="#BDFFFFFF"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Bottom section - Login card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_login_card"
        android:paddingLeft="28dp"
        android:paddingRight="28dp"
        android:paddingTop="36dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat Datang!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Masuk untuk mulai memesan lapangan favoritmu"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="32dp"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Masuk Sekarang"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/green_primary"
            android:layout_marginBottom="16dp"/>

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="0.5dp"
                android:layout_weight="1"
                android:background="@color/divider_color"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  atau lanjut sebagai  "
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0.5dp"
                android:layout_weight="1"
                android:background="@color/divider_color"/>
        </LinearLayout>

        <!-- Guest Button -->
        <Button
            android:id="@+id/btn_guest"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Tamu"
            android:textSize="15sp"
            android:textColor="@color/green_primary"
            android:backgroundTint="@android:color/transparent"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

</LinearLayout>
