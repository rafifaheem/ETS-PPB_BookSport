<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_screen">

    <!-- Success Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green_primary"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="✓"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/bg_checkmark"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pemesanan Berhasil!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lapangan telah berhasil dipesan"
            android:textSize="13sp"
            android:textColor="#BDFFFFFF"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tv_booking_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID: BSP-000000"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_booking_id"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Detail Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detail Pemesanan"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="10dp"/>

                    <include layout="@layout/item_detail_row"
                        android:id="@+id/row_name"/>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/divider_color"/>

                    <include layout="@layout/item_detail_row"
                        android:id="@+id/row_phone"/>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/divider_color"/>

                    <include layout="@layout/item_detail_row"
                        android:id="@+id/row_sport"/>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/divider_color"/>

                    <include layout="@layout/item_detail_row"
                        android:id="@+id/row_venue"/>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/divider_color"/>

                    <include layout="@layout/item_detail_row"
                        android:id="@+id/row_date"/>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/divider_color"/>

                    <include layout="@layout/item_detail_row"
                        android:id="@+id/row_time"/>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/divider_color"/>

                    <include layout="@layout/item_detail_row"
                        android:id="@+id/row_duration"/>

                    <TextView
                        android:id="@+id/tv_notes_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Catatan"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tv_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_total_price"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Pembayaran"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"/>

                <TextView
                    android:id="@+id/tv_total_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"/>
            </LinearLayout>

            <!-- Warning -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_warning"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠"
                    android:textSize="14sp"
                    android:textColor="@color/amber_dark"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Harap lakukan pembayaran dalam 30 menit"
                    android:textSize="12sp"
                    android:textColor="@color/amber_dark"/>
            </LinearLayout>

            <Button
                android:id="@+id/btn_back_home"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Kembali ke Beranda"
                android:textSize="15sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/green_primary"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
